<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StrategyTradingAppUI.Maui.MainPage"
             Title="Strategy-Auto-Trader - Trading Status"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <RefreshView Command="{Binding RefreshCommand}"
                 IsRefreshing="{Binding IsLoading}">
        <ScrollView>
            <VerticalStackLayout Padding="16,12,16,24" Spacing="8">

                <!-- Status card -->
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                     VerticalOptions="Center"
                                     Color="{Binding DaemonRunning, Converter={StaticResource BoolToColorConverter}}"/>
                            <Label Grid.Column="1"
                                   Text="{Binding DaemonRunning, Converter={StaticResource BoolToStatusTextConverter}}"
                                   FontSize="15" FontAttributes="Bold" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            <Label Grid.Column="2"
                                   Text="{Binding StatusMessage}"
                                   Style="{StaticResource CaptionLabel}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Mode flags -->
                        <HorizontalStackLayout Spacing="8">
                            <Border Style="{StaticResource Pill}"
                                    IsVisible="{Binding DryRun}"
                                    BackgroundColor="{AppThemeBinding Light=#FEF3C7, Dark=#78350F}">
                                <Label Text="PAPER TRADING" FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#92400E, Dark=#FDE68A}"/>
                            </Border>
                            <Border Style="{StaticResource Pill}"
                                    IsVisible="{Binding HaltNewEntries}"
                                    BackgroundColor="{AppThemeBinding Light=#FEE2E2, Dark=#7F1D1D}">
                                <Label Text="ENTRIES HALTED" FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#991B1B, Dark=#FECACA}"/>
                            </Border>
                            <Border Style="{StaticResource Pill}"
                                    IsVisible="{Binding PausedByUser}"
                                    BackgroundColor="{AppThemeBinding Light=#DBEAFE, Dark=#1E3A8A}">
                                <Label Text="BUYING PAUSED" FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1E40AF, Dark=#BFDBFE}"/>
                            </Border>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Positions section with Sell All button -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <Label Text="OPEN POSITIONS" Style="{StaticResource SectionHeader}" VerticalOptions="Center"/>
                    <Button Grid.Column="1"
                            Text="Sell All"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnSellAllClicked"
                            IsEnabled="{Binding IsSellInFlight, Converter={StaticResource InverseBoolConverter}}"
                            Padding="12,6"
                            FontSize="13"
                            HeightRequest="36"
                            CornerRadius="8"/>
                </Grid>

                <!-- Pause/Resume Buying buttons -->
                <HorizontalStackLayout Spacing="8">
                    <Button Text="Pause Buying"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnPauseBuyingClicked"
                            IsVisible="{Binding PausedByUser, Converter={StaticResource InverseBoolConverter}}"
                            IsEnabled="{Binding IsPauseInFlight, Converter={StaticResource InverseBoolConverter}}"
                            Padding="12,6"
                            FontSize="13"
                            HeightRequest="36"
                            CornerRadius="8"/>
                    <Button Text="Resume Buying"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnResumeBuyingClicked"
                            IsVisible="{Binding PausedByUser}"
                            IsEnabled="{Binding IsPauseInFlight, Converter={StaticResource InverseBoolConverter}}"
                            Padding="12,6"
                            FontSize="13"
                            HeightRequest="36"
                            CornerRadius="8"/>
                </HorizontalStackLayout>

                <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding Positions}">
                    <BindableLayout.EmptyView>
                        <Label Text="No open positions"
                               Style="{StaticResource CaptionLabel}"
                               FontSize="13"
                               HorizontalOptions="Center"
                               Padding="0,12"/>
                    </BindableLayout.EmptyView>
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="12">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Ticker}" Style="{StaticResource TickerLabel}" VerticalOptions="Center"/>
                                        <Border Style="{StaticResource Pill}"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource PillBackground}, Dark={StaticResource PillBackgroundDark}}">
                                            <Label Text="{Binding Currency}" FontSize="11" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource Accent}, Dark={StaticResource AccentDark}}"/>
                                        </Border>
                                    </HorizontalStackLayout>

                                    <Label Grid.Column="1"
                                           Text="{Binding UnrealizedPnl, StringFormat='{0:+0.00;-0.00;0.00}'}"
                                           FontSize="17" FontAttributes="Bold" VerticalOptions="Center"
                                           TextColor="{Binding UnrealizedPnl, Converter={StaticResource PnlColorConverter}}"/>

                                    <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,*,*">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Qty" Style="{StaticResource CaptionLabel}"/>
                                            <Label Text="{Binding Quantity, StringFormat='{0:0.####}'}" Style="{StaticResource ValueLabel}"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="Entry" Style="{StaticResource CaptionLabel}"/>
                                            <Label Text="{Binding FillPrice, StringFormat='{0:F2}'}" Style="{StaticResource ValueLabel}"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="2" Spacing="2">
                                            <Label Text="Current" Style="{StaticResource CaptionLabel}"/>
                                            <Label Text="{Binding CurrentPrice, StringFormat='{0:F2}'}" Style="{StaticResource ValueLabel}"/>
                                        </VerticalStackLayout>
                                    </Grid>

                                    <Button Grid.Row="2" Grid.ColumnSpan="2"
                                            Text="Sell Position"
                                            Style="{StaticResource PrimaryButton}"
                                            Clicked="OnSellPositionClicked"
                                            CommandParameter="{Binding Ticker}"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsSellInFlight, Converter={StaticResource InverseBoolConverter}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Pending commands section -->
                <Label Text="PENDING COMMANDS" Style="{StaticResource SectionHeader}"
                       IsVisible="{Binding PendingCommands.Count, Converter={StaticResource IntToBoolConverter}}"/>

                <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding PendingCommands}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="10">
                                    <VerticalStackLayout Spacing="4">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding Action, StringFormat='{0}'}" FontSize="15" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                            <Label Text="{Binding Ticker, StringFormat='{0}'}" FontSize="15" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource Accent}, Dark={StaticResource AccentDark}}"/>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Status, StringFormat='Status: {0}'}"
                                               Style="{StaticResource CaptionLabel}"/>
                                        <Label Text="{Binding RequestedAtUtc, StringFormat='Requested: {0:MMM d, HH:mm}'}"
                                               Style="{StaticResource CaptionLabel}"/>
                                    </VerticalStackLayout>

                                    <Button Grid.Column="1" Grid.RowSpan="2"
                                            Text="Cancel"
                                            Style="{StaticResource SecondaryButton}"
                                            Clicked="OnCancelCommandClicked"
                                            CommandParameter="{Binding Id}"
                                            Padding="12,6"
                                            FontSize="13"
                                            HeightRequest="44"
                                            WidthRequest="80"
                                            IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsSellInFlight, Converter={StaticResource InverseBoolConverter}}"
                                            VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Recent trades section -->
                <Label Text="RECENT TRADES" Style="{StaticResource SectionHeader}"/>

                <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding RecentTrades}">
                    <BindableLayout.EmptyView>
                        <Label Text="No recent trades"
                               Style="{StaticResource CaptionLabel}"
                               FontSize="13"
                               HorizontalOptions="Center"
                               Padding="0,12"/>
                    </BindableLayout.EmptyView>
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Padding="14,10">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                                    <Label Text="{Binding Ticker}" FontSize="15" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                    <Label Grid.Row="1"
                                           Text="{Binding DateClosed, StringFormat='Closed {0:d MMM yyyy}'}"
                                           Style="{StaticResource CaptionLabel}"/>
                                    <Label Grid.Column="1" Grid.RowSpan="2"
                                           Text="{Binding RoundtripPnl, StringFormat='{0:+0.00;-0.00;0.00}'}"
                                           FontSize="15" FontAttributes="Bold" VerticalOptions="Center"
                                           TextColor="{Binding RoundtripPnl, Converter={StaticResource PnlColorConverter}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
